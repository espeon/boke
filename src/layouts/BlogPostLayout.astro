---
import { type CollectionEntry } from "astro:content";
import BlueskyComments from "../components/bsky-comments.tsx";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.tsx";
import { formatDate } from "../lib/utils";
import Layout from "./Layout.astro";

interface Props {
  post: CollectionEntry<"posts">;
}

// Utility to estimate reading time
function estimateReadingTime(text: string, wordsPerMinute = 225) {
  const wordCount = text.trim().split(/\s+/).length;
  const minutes = Math.ceil(wordCount / wordsPerMinute);
  return minutes;
}

const { post } = Astro.props;
const { Content } = await post.render();
const readingTime = estimateReadingTime(post.body ?? "");
const readingHours = Math.floor(readingTime / 60);
const readingMinutes = readingTime % 60;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  date={post.data.date}
  className="blog-post-layout"
>
  <div class="blog-post-container mb-32">
    <!-- Main content area -->
    <main>
      <header class="blog-post-header">
        <h1 class="mb-1 flex flex-row gap-4 font-serif text-3xl font-medium">
          {post.data.title}
          {
            post.data.draft && (
              <p class="mt-1.5 mb-1 flex h-min flex-row items-center justify-center gap-2 rounded-full border border-neutral-400/50 bg-neutral-800 px-2 align-middle text-base font-semibold text-pink-600">
                {" "}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-eye-off-icon lucide-eye-off"
                >
                  <>
                    <path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49" />
                    <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242" />
                    <path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143" />
                    <path d="m2 2 20 20" />
                  </>
                </svg>{" "}
                Draft
              </p>
            )
          }
        </h1>
        {
          post.data.description && (
            <p class="mb-1 font-medium text-zinc-500">
              {post.data.description}
            </p>
          )
        }
        <p
          class="mb-8 flex flex-wrap items-center gap-2 font-medium text-zinc-500"
        >
          <span>{formatDate(post.data.date)}</span>
          <span class="px-1 font-black">·</span>
          <span
            >~{readingHours ? `${readingHours} hr ` : ""}{readingMinutes} min read</span
          >
          {
            post.body && /\[\^[^\]]+\]:/m.test(post.body) && (
              <button
                type="button"
                id="margin-notes-toggle"
                class="ml-2 inline-flex items-center gap-1.5 rounded-md border border-zinc-300 px-2 py-0.5 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-400 dark:hover:bg-zinc-800/50"
                aria-pressed="false"
                aria-label="Toggle margin notes"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-notebook-pen"
                >
                  <path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4" />
                  <path d="M2 6h4" />
                  <path d="M2 10h4" />
                  <path d="M2 14h4" />
                  <path d="M2 18h4" />
                  <path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.78 5.78a2 2 0 0 0-.578 1.236l-1.018 4.058a1 1 0 0 0 1.236 1.236l4.058-1.018a2 2 0 0 0 1.236-.578z" />
                </svg>
                <span id="margin-notes-toggle-label">Margin notes</span>
              </button>
            )
          }
        </p>

        <article class="prose prose-zinc dark:prose-invert max-w-none">
          <Content />
        </article>
      </header>

      <!-- Comments Section -->
      {
        post.data.bsky && (
          <section class="mt-12 border-t border-neutral-200 pt-8 dark:border-neutral-800">
            <h2 class="mb-2 text-2xl font-semibold" id="comments">
              Comments, questions, concerns.
            </h2>
            <p class="mb-6 text-zinc-300">
              Join the conversation
              <a
                href={`https://bsky.app/profile/${post.data.bsky.did}/post/${post.data.bsky.postCid}`}
                class="text-blue-800 hover:underline dark:text-blue-300"
              >
                on Bluesky.
              </a>
            </p>
            <BlueskyComments
              did={post.data.bsky.did}
              postCid={post.data.bsky.postCid}
              skipFirst={true}
              client:load
            />
          </section>
        )
      }

      <!-- Table of Contents Sidebar -->
      <TableOfContents client:load hasComments={!!post.data.bsky} />
    </main>
  </div>

  <style>
    .blog-post-container {
      position: relative;
    }

    /* TOC positioning */
    :global(.table-of-contents) {
      display: none;
    }

    /* Show TOC on larger screens - floating to the right */
    @media (min-width: 1024px) {
      :global(.table-of-contents) {
        display: block;
        position: fixed;
        right: 1rem;
        left: auto;
        top: 10%;
        width: 250px;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        z-index: 10;
        opacity: 1;
      }
    }

    /* Wider screens - move TOC further right */
    @media (min-width: 1280px) {
      :global(.table-of-contents) {
        right: 1rem;
        width: 280px;
      }
    }

    /* Extra wide screens - more space */
    @media (min-width: 1650px) {
      :global(.table-of-contents) {
        right: 4rem;
        width: 300px;
      }
    }

    /* Style the prose content */
    .prose {
      font-size: 1.1rem;
      line-height: 1.7;
    }

    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4,
    .prose h5,
    .prose h6 {
      scroll-margin-top: 2rem;
    }

    .prose h2 {
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }

    .prose h3 {
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    .prose p {
      margin-bottom: 1.5rem;
    }

    /* Mobile TOC - show as collapsible at top */
    @media (max-width: 1023px) {
      :global(.table-of-contents) {
        display: block;
        position: static;
        width: 100%;
        max-height: 200px;
        margin-bottom: 2rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(228, 228, 231, 0.5);
        border-radius: 0.5rem;
        backdrop-filter: blur(10px);
        transform: none;
        box-shadow: none;
      }

      :global(.dark .table-of-contents) {
        background: rgba(39, 39, 42, 0.8);
        border-color: rgba(63, 63, 70, 0.5);
      }
    }

    /* Fade-in animation for desktop TOC */
    @keyframes fadeInTOC {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  </style>
  <Footer />
  <script>
    const STORAGE_KEY = "margin-notes-shown";

    function applyMarginNotesState() {
      const shown = localStorage.getItem(STORAGE_KEY) === "true";
      document.body.classList.toggle("margin-notes-shown", shown);

      const label = document.getElementById("margin-notes-toggle-label");
      if (label) {
        label.textContent = shown ? "Margin notes on" : "Margin notes";
      }
      const buttons = document.querySelectorAll<HTMLButtonElement>(
        "#margin-notes-toggle",
      );
      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", shown ? "true" : "false");
      });
    }

    function setupToggle() {
      document.addEventListener("click", (event) => {
        const target = event.target as Element | null;
        const button = target?.closest("#margin-notes-toggle");
        if (button) {
          const currentlyShown =
            document.body.classList.contains("margin-notes-shown");
          localStorage.setItem(STORAGE_KEY, String(!currentlyShown));
          applyMarginNotesState();
          return;
        }
        const noteLink = target?.closest("a[href^='#note-'], a[href^='#ref-']");
        if (noteLink) {
          event.preventDefault();
          const href = noteLink.getAttribute("href");
          if (href) {
            history.replaceState(null, "", href);
          }
        }
      });
    }

    applyMarginNotesState();
    setupToggle();

    document.addEventListener("astro:page-load", applyMarginNotesState);
  </script>
</Layout>
